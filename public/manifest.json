{
  "manifest_version": 3,
  "name": "Chro-Jarvis",
  "version": "1.0.0",
  "description": "智能 Chrome 插件，提供 AI 问答、页面翻译等功能",
  "permissions": ["sidePanel", "tabs", "storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Chro-Jarvis",
    "default_popup": "index.html"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content-scripts/index.ts"]
    }
  ],
  "icons": {
    "16": "vite.svg",
    "48": "vite.svg",
    "128": "vite.svg"
  }
}
